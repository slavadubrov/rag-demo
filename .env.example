# Required for real embeddings and answers. Without it, the pipeline runs in
# offline mode (deterministic hash embeddings + evidence-only stub answer).
OPENAI_API_KEY="your-api-key-here"

# Optional overrides (defaults shown)
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536
# ANSWER_MODEL=gpt-4o-mini
# EMBED_BACKEND=openai            # "openai" or "hash"
# PAGE_RENDER_DPI=150
# MAX_PAGES_PER_DOC=60
# GRADIO_SERVER_PORT=7860
